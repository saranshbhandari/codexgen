private void addResultSetShortcuts(String taskPrefix,
                                   List<List<Map<String, Object>>> indexedResultSets,
                                   VariableStore varstore) {

    List<Map<String, Object>> firstResultSet =
            indexedResultSets.size() >= 1 ? indexedResultSets.get(0) : Collections.emptyList();

    varstore.addVariable("${" + taskPrefix + "FirstResultSet}", firstResultSet);
    varstore.addVariable("${" + taskPrefix + "FirstResultSetCount}", firstResultSet.size());
    varstore.addVariable("${" + taskPrefix + "FirstResultSetColumns}", extractColumns(firstResultSet));
    varstore.addVariable("${" + taskPrefix + "FirstResultSetFirstRow}",
            firstResultSet.isEmpty() ? Collections.emptyMap() : firstResultSet.get(0));
    varstore.addVariable("${" + taskPrefix + "FirstResultSetLastRow}",
            firstResultSet.isEmpty() ? Collections.emptyMap() : firstResultSet.get(firstResultSet.size() - 1));

    List<Map<String, Object>> secondResultSet =
            indexedResultSets.size() >= 2 ? indexedResultSets.get(1) : Collections.emptyList();

    varstore.addVariable("${" + taskPrefix + "SecondResultSet}", secondResultSet);
    varstore.addVariable("${" + taskPrefix + "SecondResultSetCount}", secondResultSet.size());
    varstore.addVariable("${" + taskPrefix + "SecondResultSetColumns}", extractColumns(secondResultSet));
    varstore.addVariable("${" + taskPrefix + "SecondResultSetFirstRow}",
            secondResultSet.isEmpty() ? Collections.emptyMap() : secondResultSet.get(0));
    varstore.addVariable("${" + taskPrefix + "SecondResultSetLastRow}",
            secondResultSet.isEmpty() ? Collections.emptyMap() : secondResultSet.get(secondResultSet.size() - 1));

    varstore.addVariable("${" + taskPrefix + "MainResultSet}", firstResultSet);
}
