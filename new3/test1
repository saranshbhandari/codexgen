private static List<PathToken> tokenizePath(String raw) {
    List<PathToken> out = new ArrayList<>();
    StringBuilder buf = new StringBuilder();
    boolean inBracket = false;
    boolean nullSafe = false;

    for (int i = 0; i < raw.length(); i++) {
        char c = raw.charAt(i);

        if (!inBracket && c == '?' && i + 1 < raw.length() && raw.charAt(i + 1) == '.') {
            nullSafe = true;
            i++; // skip '.'
            continue;
        }

        if (!inBracket && c == '.') {
            if (buf.length() > 0) {
                out.add(new PathToken(buf.toString(), nullSafe));
                buf.setLength(0);
            }
            nullSafe = false;
            continue;
        }

        if (!inBracket && c == '[') {
            if (buf.length() > 0) {
                out.add(new PathToken(buf.toString(), nullSafe));
                buf.setLength(0);
            }
            nullSafe = false;
            inBracket = true;
            continue;
        }

        if (inBracket && c == ']') {
            if (buf.length() > 0) {
                out.add(new PathToken(buf.toString(), false));
                buf.setLength(0);
            }
            inBracket = false;
            continue;
        }

        buf.append(c);
    }

    if (buf.length() > 0) {
        out.add(new PathToken(buf.toString(), nullSafe));
    }

    return out;
}








private Object resolveNext(Object cur, String key) {
    try {
        if (cur instanceof Map) {
            return ((Map<?, ?>) cur).get(key);
        }

        if (cur instanceof List) {
            int idx = Integer.parseInt(key.trim());
            List<?> list = (List<?>) cur;
            if (idx < 0 || idx >= list.size()) {
                return null;
            }
            return list.get(idx);
        }

        if (cur.getClass().isArray()) {
            int idx = Integer.parseInt(key.trim());
            int len = Array.getLength(cur);
            if (idx < 0 || idx >= len) {
                return null;
            }
            return Array.get(cur, idx);
        }

        Method m = cur.getClass().getMethod(
                "get" + Character.toUpperCase(key.charAt(0)) + key.substring(1)
        );
        return m.invoke(cur);

    } catch (Exception e) {
        return null;
    }
}



